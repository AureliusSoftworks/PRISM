#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

DEFAULT_IOS_SIMULATOR_ID="29D05410-1ED7-4282-A174-92A2FDB70FCD"
IOS_BUNDLE_ID="com.localai.prism-ios"
IOS_APP_PATH="apps/ios-client/DerivedData/Build/Products/Debug-iphonesimulator/Prism.app"
IOS_DEVICE_APP_PATH="apps/ios-client/DerivedData/Build/Products/Debug-iphoneos/Prism.app"
API_PORT="18787"
WEB_PORT="18788"

MAC_CLIENT_BUNDLE_ID="com.localai.prism-client"
MAC_CLIENT_APP_PATH="apps/client-mac/DerivedData/Build/Products/Debug/Prism.app"

MAC_SERVER_BUNDLE_ID="com.localai.prism-server"
MAC_SERVER_APP_PATH="apps/server-mac/DerivedData/Build/Products/Debug/Prism Server.app"

usage() {
  cat <<'USAGE'
Usage:
  prism ios
  prism phone
  prism mac-client
  prism mac-server
  prism web
  prism standalone
  prism standalone-installer
  prism reset [--force]

Aliases:
  prism iphone
  prism client
  prism server

Notes:
  prism web now runs the combined dev launcher (`npm run dev`) which
  starts/restarts both API (http://localhost:18787) and web
  (http://localhost:18788) together in one foreground session.
  prism standalone builds the desktop app and opens the folder containing
  the latest macOS DMG.
  prism standalone-installer opens the latest macOS Prism Desktop installer
  DMG (and builds one first if missing).
  prism reset removes local Prism account/data state (factory reset) while
  intentionally keeping launcher configuration files.

Environment:
  SIMULATOR_ID="Simulator UDID" prism ios
  PHONE_DEVICE_ID="Device UDID" prism phone
USAGE
}

print_reset_warning() {
  cat <<'RESET_WARNING'
WARNING: prism reset will permanently delete local Prism data:
  - SQLite database files (localai.db, WAL, SHM)
  - generated-images directories
  - local Qdrant storage directories
  - Prism app runtime logs/cache directories

This keeps launcher configuration files (for example .env) in place.
RESET_WARNING
}

confirm_reset() {
  local reply
  print_reset_warning
  printf '\nType RESET to continue: '
  read -r reply
  if [[ "$reply" != "RESET" ]]; then
    echo "Reset cancelled."
    exit 0
  fi
}

stop_reset_processes() {
  local ports=(18787 18788 18789 18790 6333)
  local port=""
  for port in "${ports[@]}"; do
    free_tcp_port "$port"
  done

  pkill -f "Prism Server.app/Contents/MacOS/Prism Server" >/dev/null 2>&1 || true
  pkill -f "Prism.app/Contents/MacOS/Prism" >/dev/null 2>&1 || true
  pkill -f "Prism Desktop.app/Contents/MacOS/Prism Desktop" >/dev/null 2>&1 || true
}

delete_path() {
  local path="$1"
  local label="$2"
  if [[ -e "$path" ]]; then
    rm -rf "$path"
    echo "Removed: $label"
  else
    echo "Missing (skipped): $label"
  fi
}

run_reset() {
  local force_mode=0
  if [[ "${1:-}" == "--force" ]]; then
    force_mode=1
  elif [[ -n "${1:-}" ]]; then
    echo "Unknown reset flag: ${1}" >&2
    echo "Usage: prism reset [--force]" >&2
    exit 64
  fi

  if [[ "$force_mode" -eq 0 ]]; then
    confirm_reset
  fi

  stop_reset_processes

  local localai_data_dir="${LOCALAI_DATA_DIR:-}"
  local api_dev_data_dir="$REPO_ROOT/apps/api/data"
  local mac_app_support="$HOME/Library/Application Support/Prism"
  local desktop_app_data="$HOME/Library/Application Support/com.localai.prism-desktop"
  local client_webkit_local_storage="$HOME/Library/Containers/com.localai.prism-client/Data/Library/WebKit/WebsiteData/LocalStorage"

  delete_path "$api_dev_data_dir/localai.db" "repo dev DB (apps/api/data/localai.db)"
  delete_path "$api_dev_data_dir/localai.db-wal" "repo dev DB WAL (apps/api/data/localai.db-wal)"
  delete_path "$api_dev_data_dir/localai.db-shm" "repo dev DB SHM (apps/api/data/localai.db-shm)"
  delete_path "$api_dev_data_dir/generated-images" "repo generated images (apps/api/data/generated-images)"

  if [[ -n "$localai_data_dir" ]]; then
    delete_path "$localai_data_dir/localai.db" "LOCALAI_DATA_DIR DB ($localai_data_dir/localai.db)"
    delete_path "$localai_data_dir/localai.db-wal" "LOCALAI_DATA_DIR DB WAL ($localai_data_dir/localai.db-wal)"
    delete_path "$localai_data_dir/localai.db-shm" "LOCALAI_DATA_DIR DB SHM ($localai_data_dir/localai.db-shm)"
    delete_path "$localai_data_dir/generated-images" "LOCALAI_DATA_DIR generated images ($localai_data_dir/generated-images)"
  fi

  delete_path "$mac_app_support/Data" "mac server data (~/Library/Application Support/Prism/Data)"
  delete_path "$mac_app_support/Qdrant/storage" "mac server qdrant storage (~/Library/Application Support/Prism/Qdrant/storage)"
  delete_path "$mac_app_support/Logs" "mac server logs (~/Library/Application Support/Prism/Logs)"

  delete_path "$desktop_app_data" "desktop app data (~/Library/Application Support/com.localai.prism-desktop)"

  delete_path "$client_webkit_local_storage/http_localhost_18788.localstorage" "client localStorage localhost:18788"
  delete_path "$client_webkit_local_storage/http_localhost_18788.localstorage-shm" "client localStorage SHM localhost:18788"
  delete_path "$client_webkit_local_storage/http_localhost_18788.localstorage-wal" "client localStorage WAL localhost:18788"
  delete_path "$client_webkit_local_storage/http_localhost_18790.localstorage" "client localStorage localhost:18790"
  delete_path "$client_webkit_local_storage/http_localhost_18790.localstorage-shm" "client localStorage SHM localhost:18790"
  delete_path "$client_webkit_local_storage/http_localhost_18790.localstorage-wal" "client localStorage WAL localhost:18790"

  echo
  echo "Factory reset complete."
  echo "Kept intentionally: launcher config files (for example .env files)."
}

resolve_phone_device_id() {
  local explicit_device_id="${PHONE_DEVICE_ID:-${DEVICE_ID:-}}"
  if [[ -n "$explicit_device_id" ]]; then
    printf '%s\n' "$explicit_device_id"
    return
  fi

  local devices_json
  devices_json="$(mktemp -t prism-devices.XXXXXX.json)"
  xcrun devicectl list devices --json-output "$devices_json" --quiet >/dev/null

  python3 - "$devices_json" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    payload = json.load(handle)

devices = payload.get("result", {}).get("devices", [])
phones = [
    device for device in devices
    if device.get("hardwareProperties", {}).get("platform") == "iOS"
    and device.get("hardwareProperties", {}).get("reality") == "physical"
]

if not phones:
    print("No paired physical iPhone found. Connect and unlock your phone, or run PHONE_DEVICE_ID=\"Device UDID\" prism phone.", file=sys.stderr)
    sys.exit(1)

if len(phones) > 1:
    names = ", ".join(phone.get("deviceProperties", {}).get("name", "Unnamed iPhone") for phone in phones)
    print(f"Multiple physical iPhones found ({names}); using the first. Set PHONE_DEVICE_ID to choose one.", file=sys.stderr)

selected = phones[0]
name = selected.get("deviceProperties", {}).get("name", "iPhone")
udid = selected.get("hardwareProperties", {}).get("udid") or selected.get("identifier")
print(f"Using {name} ({udid})", file=sys.stderr)
print(udid)
PY

  rm -f "$devices_json"
}

wait_for_app_exit() {
  local bundle_id="$1"
  local process_pattern="$2"
  local attempts=0

  while pgrep -f "$process_pattern" >/dev/null 2>&1 && [[ "$attempts" -lt 30 ]]; do
    sleep 0.2
    attempts=$((attempts + 1))
  done

  if pgrep -f "$process_pattern" >/dev/null 2>&1; then
    echo "Timed out waiting for $bundle_id to quit." >&2
    exit 1
  fi
}

run_ios() {
  local simulator_id="${SIMULATOR_ID:-$DEFAULT_IOS_SIMULATOR_ID}"

  open -a Simulator
  xcrun simctl boot "$simulator_id" 2>/dev/null || true
  xcrun simctl bootstatus "$simulator_id" -b
  xcrun simctl terminate "$simulator_id" "$IOS_BUNDLE_ID" 2>/dev/null || true

  xcodebuild \
    -project "apps/ios-client/PrismIOS.xcodeproj" \
    -scheme PrismIOS \
    -configuration Debug \
    -derivedDataPath "apps/ios-client/DerivedData" \
    -sdk iphonesimulator \
    -destination "platform=iOS Simulator,id=$simulator_id" \
    build

  xcrun simctl install "$simulator_id" "$IOS_APP_PATH"
  xcrun simctl launch "$simulator_id" "$IOS_BUNDLE_ID"
}

run_phone() {
  local device_id
  device_id="$(resolve_phone_device_id)"

  xcodebuild \
    -project "apps/ios-client/PrismIOS.xcodeproj" \
    -scheme PrismIOS \
    -configuration Debug \
    -derivedDataPath "apps/ios-client/DerivedData" \
    -sdk iphoneos \
    -destination "platform=iOS,id=$device_id" \
    build

  xcrun devicectl device install app --device "$device_id" "$IOS_DEVICE_APP_PATH"
  xcrun devicectl device process launch --device "$device_id" --terminate-existing "$IOS_BUNDLE_ID"
}

run_mac_client() {
  osascript -e "quit app id \"$MAC_CLIENT_BUNDLE_ID\"" >/dev/null 2>&1 || true
  wait_for_app_exit "$MAC_CLIENT_BUNDLE_ID" "$MAC_CLIENT_APP_PATH/Contents/MacOS/Prism"

  xcodebuild \
    -project "apps/client-mac/PrismClient.xcodeproj" \
    -scheme PrismClient \
    -configuration Debug \
    -derivedDataPath "apps/client-mac/DerivedData" \
    build

  open "$MAC_CLIENT_APP_PATH"
}

run_mac_server() {
  osascript -e "quit app id \"$MAC_SERVER_BUNDLE_ID\"" >/dev/null 2>&1 || true
  wait_for_app_exit "$MAC_SERVER_BUNDLE_ID" "$MAC_SERVER_APP_PATH/Contents/MacOS/Prism Server"

  xcodebuild \
    -project "apps/server-mac/PrismServer.xcodeproj" \
    -scheme PrismServer \
    -configuration Debug \
    -derivedDataPath "apps/server-mac/DerivedData" \
    build

  open "$MAC_SERVER_APP_PATH"
}

free_tcp_port() {
  local port="$1"
  local pids

  pids="$(lsof -nP -iTCP:"$port" -sTCP:LISTEN -t 2>/dev/null || true)"
  if [[ -z "$pids" ]]; then
    return
  fi

  echo "Port $port is already in use. Stopping existing process(es): $pids"
  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    kill "$pid" 2>/dev/null || true
  done <<< "$pids"

  sleep 0.5

  pids="$(lsof -nP -iTCP:"$port" -sTCP:LISTEN -t 2>/dev/null || true)"
  if [[ -n "$pids" ]]; then
    echo "Force-stopping stubborn process(es) on port $port: $pids"
    while IFS= read -r pid; do
      [[ -z "$pid" ]] && continue
      kill -9 "$pid" 2>/dev/null || true
    done <<< "$pids"
  fi
}

# Foreground long-running dev server; exec replaces the script process so
# Ctrl+C is delivered straight to `next dev` without a stray bash hop.
run_web() {
  free_tcp_port "$API_PORT"
  free_tcp_port "$WEB_PORT"
  exec npm run dev
}

run_standalone() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "prism standalone currently targets macOS DMG output and is only supported on macOS." >&2
    exit 1
  fi

  echo "Building Prism Desktop DMG..."
  npm run desktop:stage-runtime
  npm run build -w apps/desktop

  local dmg_path=""
  local candidate=""
  local newest_mtime=0
  local mtime=0

  shopt -s nullglob
  for candidate in \
    "$REPO_ROOT"/dist-desktop/Prism-Desktop-v*.dmg \
    "$REPO_ROOT"/apps/desktop/src-tauri/target/release/bundle/dmg/*.dmg; do
    mtime="$(stat -f %m "$candidate" 2>/dev/null || echo 0)"
    if [[ "$mtime" -gt "$newest_mtime" ]]; then
      newest_mtime="$mtime"
      dmg_path="$candidate"
    fi
  done
  shopt -u nullglob

  if [[ -z "$dmg_path" ]]; then
    echo "Could not locate a desktop installer DMG after build." >&2
    exit 1
  fi

  local dmg_dir
  dmg_dir="$(dirname "$dmg_path")"
  echo "Opening DMG folder:"
  echo "  $dmg_dir"
  open "$dmg_dir"
}

run_standalone_installer() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "prism standalone-installer currently opens a macOS DMG installer and is only supported on macOS." >&2
    exit 1
  fi
  local dmg_path=""
  local candidate=""
  local newest_mtime=0
  local mtime=0

  shopt -s nullglob
  for candidate in \
    "$REPO_ROOT"/dist-desktop/Prism-Desktop-v*.dmg \
    "$REPO_ROOT"/apps/desktop/src-tauri/target/release/bundle/dmg/*.dmg; do
    mtime="$(stat -f %m "$candidate" 2>/dev/null || echo 0)"
    if [[ "$mtime" -gt "$newest_mtime" ]]; then
      newest_mtime="$mtime"
      dmg_path="$candidate"
    fi
  done
  shopt -u nullglob

  if [[ -z "$dmg_path" ]]; then
    echo "No desktop installer DMG found. Building one now..."
    npm run desktop:stage-runtime
    npm run build -w apps/desktop

    shopt -s nullglob
    for candidate in \
      "$REPO_ROOT"/dist-desktop/Prism-Desktop-v*.dmg \
      "$REPO_ROOT"/apps/desktop/src-tauri/target/release/bundle/dmg/*.dmg; do
      mtime="$(stat -f %m "$candidate" 2>/dev/null || echo 0)"
      if [[ "$mtime" -gt "$newest_mtime" ]]; then
        newest_mtime="$mtime"
        dmg_path="$candidate"
      fi
    done
    shopt -u nullglob
  fi

  if [[ -z "$dmg_path" ]]; then
    echo "Could not locate a desktop installer DMG after build." >&2
    exit 1
  fi

  echo "Opening desktop installer:"
  echo "  $dmg_path"
  open "$dmg_path"
}

cd "$REPO_ROOT"

case "${1:-}" in
  ios | iphone)
    run_ios
    ;;
  phone)
    run_phone
    ;;
  mac-client | client)
    run_mac_client
    ;;
  mac-server | server)
    run_mac_server
    ;;
  web)
    run_web
    ;;
  standalone | desktop)
    run_standalone
    ;;
  standalone-installer | desktop-installer)
    run_standalone_installer
    ;;
  standalone-dev | desktop-dev)
    run_standalone
    ;;
  reset)
    run_reset "${2:-}"
    ;;
  help | -h | --help)
    usage
    ;;
  *)
    usage >&2
    exit 64
    ;;
esac
