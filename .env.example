API_PORT=8787
SESSION_COOKIE_NAME=localai_session
SESSION_TTL_HOURS=24
ENCRYPTION_MASTER_KEY=change-me-to-a-long-random-secret
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
QDRANT_URL=http://localhost:6333
NEXT_PUBLIC_API_BASE_URL=http://192.168.0.202:8787

# Disables Next.js anonymous telemetry so LOCAL mode truly keeps packets
# on-network. The web Dockerfile also sets this for builds/runtime.
NEXT_TELEMETRY_DISABLED=1

# Extra origins allowed to hit the Next.js dev server. The host's LAN IPs
# are auto-detected at startup; set this only if you also want to
# whitelist a hostname / reverse-proxy alias / .local domain.
# ALLOWED_DEV_ORIGINS=my-laptop.local,some-other-host.lan

# Enable the in-app Developer Tools modal (key glyph next to the theme
# toggle): "Add 10 random bots" + "Delete all bots". Off by default;
# keep it unset on `main` so release builds never render the surface.
# Next.js inlines NEXT_PUBLIC_* at build time, so a change here requires
# rebuilding the web app (or restarting `next dev`) to take effect.
# NEXT_PUBLIC_DEV_TOOLS=1
