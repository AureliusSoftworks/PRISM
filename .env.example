API_PORT=18787
WEB_PORT=18788
PRISM_SERVER_NAME=Prism Server

# ── Network access (private by default) ──────────────────────────────────────
# When false, Prism stays on this machine only. Flip to true (and, for Docker,
# also set the PRISM_BIND_HOST / PRISM_WEB_LAN lines below) to let other devices
# on your local network reach it. You can also toggle this from Settings ->
# Network in the app, then restart Prism to apply.
PRISM_LAN_ACCESS=false
# mDNS/Bonjour advertisement. Only ever advertises when PRISM_LAN_ACCESS is also
# true, so leaving it on does not expose anything by itself.
PRISM_DISCOVERY_ENABLED=true

SESSION_COOKIE_NAME=localai_session
SESSION_TTL_HOURS=24
ENCRYPTION_MASTER_KEY=change-me-to-a-long-random-secret
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_AUXILIARY_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
BRAVE_SEARCH_API_KEY=
QDRANT_URL=http://localhost:6333
# Same-origin by default so a fresh install always talks to its own API through
# the web proxy. Only set an explicit http://<ip>:18787 if you intentionally run
# the API on a different host.
NEXT_PUBLIC_API_BASE_URL=/api

# ── Docker: expose on the local network ──────────────────────────────────────
# Published ports bind to 127.0.0.1 by default (private). To reach Prism from
# other devices, uncomment all three and run `docker compose up -d`:
# PRISM_BIND_HOST=0.0.0.0
# PRISM_LAN_ACCESS=true
# PRISM_WEB_LAN=1

# Disables Next.js anonymous telemetry so LOCAL mode truly keeps packets
# on-network. The web Dockerfile also sets this for builds/runtime.
NEXT_TELEMETRY_DISABLED=1

# Web only: `/dev …` composer shortcuts on the Prism UI. Enabled automatically
# during `npm run dev`. Set to 1 only if you want them in production-like builds.
# NEXT_PUBLIC_PRISM_DEV_COMMANDS=1

# Extra origins allowed to hit the Next.js dev server. The host's LAN IPs
# are auto-detected at startup; set this only if you also want to
# whitelist a hostname / reverse-proxy alias / .local domain.
# ALLOWED_DEV_ORIGINS=my-laptop.local,some-other-host.lan
