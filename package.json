{
  "name": "localai-chatgov",
  "private": true,
  "type": "module",
  "version": "0.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "test:coverage": "node scripts/run-tests.mjs --coverage",
    "test:e2e": "playwright test --grep-invert @visual",
    "test:visual": "playwright test --grep @visual",
    "test:perf": "npm --prefix packages/config run build && npm --prefix packages/shared run build && node --experimental-strip-types scripts/perf/test-performance.ts",
    "dev": "node --env-file-if-exists=.env scripts/dev.mjs",
    "version:set": "node scripts/set-version.mjs",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "desktop": "npm run desktop:dev",
    "desktop:stage-runtime": "node scripts/stage-desktop-runtime.mjs --output-dir runtime",
    "desktop:dev": "npm run desktop:stage-runtime && npm run dev -w apps/desktop",
    "desktop:build": "npm run desktop:stage-runtime && npm run build -w apps/desktop",
    "desktop:package:mac": "bash scripts/package-desktop-macos.sh",
    "desktop:package:linux": "bash scripts/package-desktop-linux.sh",
    "desktop:package:windows": "pwsh scripts/package-desktop-windows.ps1",
    "steam:export-desktop-depots": "node scripts/steam/export-desktop-depots.mjs",
    "kb": "node --env-file-if-exists=.env scripts/kb.mjs sync",
    "kb:incremental": "node --env-file-if-exists=.env scripts/kb.mjs incremental",
    "kb:augment": "node --env-file-if-exists=.env scripts/kb.mjs augment",
    "kb:install-hook": "bash scripts/install_kb_hook.sh",
    "eval:experimental-effort": "node --env-file-if-exists=.env --experimental-strip-types apps/api/src/evals/experimental-effort.ts",
    "eval-experimental-effort": "node --env-file-if-exists=.env --experimental-strip-types apps/api/src/evals/experimental-effort.ts",
    "eval:effort-ladder": "node --env-file-if-exists=.env --experimental-strip-types apps/api/src/evals/effort-ladder.ts",
    "eval-effort-ladder": "node --env-file-if-exists=.env --experimental-strip-types apps/api/src/evals/effort-ladder.ts",
    "build": "npm run build -w packages/shared && npm run build -w packages/config && npm run build -w apps/api && npm run build -w apps/web",
    "lint": "npm run lint -w apps/api && npm run lint -w apps/web",
    "typecheck": "npm run typecheck -w packages/shared && npm run typecheck -w packages/config && npm run typecheck -w apps/api && npm run typecheck -w apps/web",
    "wiki:status": "wk status --json",
    "wiki:spin": "wk spin --profile mixed --json",
    "wiki:check": "wk validate",
    "wiki:render": "wk validate && wk render",
    "wiki:site": "wk validate && wk render && wk site --audience all",
    "wiki:site:user": "wk validate && wk render && wk site --audience user",
    "wiki:closeout": "wk closeout --profile mixed --audience all"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@thjodann/wk": "^1.0.4"
  }
}
