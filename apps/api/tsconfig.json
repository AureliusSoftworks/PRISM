{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@localai/shared": [
        "../../packages/shared/src"
      ],
      "@localai/config": [
        "../../packages/config/src"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/__tests__/**/*"
  ]
}
