{
  "name": "@localai/api",
  "version": "0.12.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/fetch-builtin-tts-model.mjs",
    "dev": "node --env-file-if-exists=../../.env --watch --experimental-strip-types src/server.ts",
    "build": "tsc -p tsconfig.json",
    "prestart": "node ../../scripts/fetch-builtin-tts-model.mjs",
    "start": "node --env-file-if-exists=../../.env dist/server.js",
    "test": "node --test --experimental-strip-types src/__tests__/*.test.ts",
    "test:coverage": "node --test --experimental-strip-types --experimental-test-coverage --test-coverage-lines=85 --test-coverage-branches=65 --test-coverage-functions=85 --test-coverage-exclude='**/packages/**' --test-coverage-exclude='src/server.ts' src/__tests__/*.test.ts",
    "pretest": "npm --prefix ../../packages/config run build && npm --prefix ../../packages/shared run build",
    "pretest:coverage": "npm --prefix ../../packages/config run build && npm --prefix ../../packages/shared run build",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@localai/config": "file:../../packages/config",
    "@localai/shared": "file:../../packages/shared",
    "dnssd-advertise": "^1.1.4",
    "docx": "^9.7.1",
    "fflate": "^0.8.3",
    "kokoro-js": "^1.2.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.9.3"
  }
}
