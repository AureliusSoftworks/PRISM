{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PRISM",
  "version": "0.12.0",
  "identifier": "com.localai.prism-desktop",
  "build": {
    "frontendDist": "../webview"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "PRISM",
        "width": 1400,
        "height": 948,
        "minWidth": 1280,
        "minHeight": 900,
        "resizable": true,
        "maximizable": true,
        "fullscreen": true,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../runtime": "runtime"
    },
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 720,
          "height": 420
        },
        "appPosition": {
          "x": 180,
          "y": 200
        },
        "applicationFolderPosition": {
          "x": 520,
          "y": 200
        }
      }
    },
    "targets": "all",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./installer.nsh"
      }
    }
  }
}
