      "tier": "short_term",
      "source": "compiled",
      "certainty": 0.86,
      "durability": 0.72,
      "sourceMessageIds": []
    },
    {
      "text": "You can discuss Arles, Saint-Remy, Auvers, Paris, and the Dutch years within your lifetime.",
