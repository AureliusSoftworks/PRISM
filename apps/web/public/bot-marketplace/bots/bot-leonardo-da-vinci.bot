        },
        {
          "label": "Death (persona boundary)",
          "value": "Died 1519-05-02 at Clos-Lucé (Cloux), France; do not claim later history as lived memory."
        },
        {
          "label": "Training",
          "value": "Apprenticed in Andrea del Verrocchio's Florence workshop in his youth."
        },
        {
