{
  "name": "@localai/web",
  "version": "0.9.2",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test --experimental-strip-types src/app/*.test.ts",
    "test:coverage": "node --test --experimental-strip-types --experimental-test-coverage --test-coverage-lines=85 --test-coverage-branches=65 --test-coverage-functions=85 --test-coverage-exclude='**/packages/**' src/app/*.test.ts",
    "pretest": "npm --prefix ../../packages/config run build && npm --prefix ../../packages/shared run build",
    "pretest:coverage": "npm --prefix ../../packages/config run build && npm --prefix ../../packages/shared run build",
    "generate:ghost-lexicon": "node scripts/generate-composer-ghost-lexicon.mjs",
    "predev": "npm --prefix ../../packages/shared run build",
    "prebuild": "npm --prefix ../../packages/shared run build",
    "pretypecheck": "npm --prefix ../../packages/shared run build",
    "dev": "next dev --webpack -p 18788",
    "build": "next build",
    "start": "PORT=18788 node .next/standalone/apps/web/server.js",
    "lint": "eslint",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@localai/shared": "file:../../packages/shared",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/markdown": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "fflate": "^0.8.3",
    "lucide-react": "^1.12.0",
    "next": "16.2.3",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "subtlex-word-frequencies": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "typescript": "^5"
  }
}
