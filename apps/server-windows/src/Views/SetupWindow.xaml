<Window x:Class="PrismServer.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prism Server" Width="560" Height="680" MinWidth="520" MinHeight="560">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Orientation="Vertical">
            <TextBlock Text="Welcome to Prism Server" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Everything runs on your PC. Prism only talks to services you start or approve - your data stays local under your control."
                       TextWrapping="Wrap" Margin="0,6,0,12" Foreground="DimGray" />

            <TextBlock Text="{Binding SetupMessage}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,12" />

            <Button Content="{Binding PrimaryActionTitle}" Command="{Binding SetUpPrismCommand}" Height="38" Margin="0,0,0,16" />

            <Border Padding="12" CornerRadius="8" Background="#10000000" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Readiness" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                    <TextBlock Text="Server Runtime" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DependencyStatus.ServerRuntime.Detail}" TextWrapping="Wrap" Foreground="DimGray" Margin="0,0,0,8" />
                    <TextBlock Text="Memory Engine" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DependencyStatus.MemoryEngine.Detail}" TextWrapping="Wrap" Foreground="DimGray" Margin="0,0,0,8" />
                    <Button Content="Start Memory Engine" Command="{Binding StartMemoryEngineCommand}" HorizontalAlignment="Left" Margin="0,0,0,8" />
                    <TextBlock Text="Local AI Engine" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DependencyStatus.LocalAI.Ollama.Detail}" TextWrapping="Wrap" Foreground="DimGray" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding DependencyStatus.LocalAI.DefaultModel.Name}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DependencyStatus.LocalAI.DefaultModel.Detail}" TextWrapping="Wrap" Foreground="DimGray" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding DependencyStatus.LocalAI.EmbeddingModel.Name}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DependencyStatus.LocalAI.EmbeddingModel.Detail}" TextWrapping="Wrap" Foreground="DimGray" Margin="0,0,0,8" />
                    <Button Content="{Binding RequiredModelDownloadLabel, StringFormat=Download {0}}" Command="{Binding DownloadDefaultModelCommand}" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="Restart Server" Command="{Binding RestartCommand}" Margin="0,0,8,0" />
                <Button Content="Refresh status" Command="{Binding RefreshCommand}" />
            </StackPanel>

            <Expander Header="Advanced" Margin="0,0,0,16">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Server name" Margin="0,4,8,8" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="1" Text="API port" Margin="0,4,8,8" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ApiPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="2" Text="Web port" Margin="0,4,8,8" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding WebPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="3" Text="Advertise on LAN" Margin="0,4,8,8" />
                    <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding DiscoveryEnabled}" Margin="0,4,0,8" />
                    <TextBlock Grid.Row="4" Text="Ollama host" Margin="0,4,8,8" />
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding OllamaHost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="5" Text="Ollama model" Margin="0,4,8,8" />
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding OllamaModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="6" Text="Auxiliary model" Margin="0,4,8,8" />
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding OllamaAuxiliaryModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="7" Text="Embedding model" Margin="0,4,8,8" />
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding OllamaEmbeddingModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="8" Text="Qdrant URL" Margin="0,4,8,8" />
                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding QdrantUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="9" Text="Encryption key" Margin="0,4,8,8" />
                    <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding EncryptionMasterKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="10" Text="Session cookie" Margin="0,4,8,8" />
                    <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding SessionCookieName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="11" Text="Session TTL hours" Margin="0,4,8,8" />
                    <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding SessionTtlHours, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="12" Text="OpenAI API key" Margin="0,4,8,8" />
                    <TextBox Grid.Row="12" Grid.Column="1" Text="{Binding OpenAiApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <StackPanel Grid.Row="13" Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Save" Command="{Binding SaveConfigCommand}" Margin="0,0,8,0" />
                        <Button Content="Save and refresh" Command="{Binding SaveAndRefreshCommand}" />
                    </StackPanel>
                </Grid>
            </Expander>

            <TextBlock Text="{Binding OwnershipFootnote}" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,16" />

            <Border Padding="12" CornerRadius="8" Background="#10000000" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Pair a Client App" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Text="Generate a short code, then type it into Prism Client on your device." TextWrapping="Wrap" Foreground="DimGray" Margin="0,4,0,8" />
                    <TextBlock Text="{Binding PairingCodeText}" FontFamily="Consolas" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding PairingExpirationText}" Foreground="DimGray" Margin="0,4,0,8" />
                    <Button Content="Generate Pairing Code" Command="{Binding GeneratePairingCodeCommand}" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <TextBlock Text="Server-only mode: Prism Server is ready for a client app to pair. The bundled web dashboard is not part of the user-facing flow."
                       TextWrapping="Wrap" Foreground="DimGray" FontSize="12" />
        </StackPanel>
    </ScrollViewer>
</Window>
