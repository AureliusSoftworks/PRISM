<Window x:Class="PrismServer.Views.LogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prism Server Logs" Width="820" Height="580" MinWidth="620" MinHeight="400">
    <DockPanel Margin="16">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Runtime Logs" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
            <Button Content="Refresh" Width="90" HorizontalAlignment="Right" DockPanel.Dock="Right" Click="RefreshClicked" />
        </DockPanel>
        <TextBox x:Name="LogTextBox" FontFamily="Consolas" FontSize="12" IsReadOnly="True"
                 TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
    </DockPanel>
</Window>
